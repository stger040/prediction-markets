# Copy this file to .env.local and fill in your values
# -------------------------------------------------------

# ── US MODE (Kalshi + IBKR ForecastEx) ──────────────────
#
# Kalshi credentials (sign up at https://kalshi.com)
KALSHI_EMAIL=your@email.com
KALSHI_PASSWORD=yourpassword
#
# IBKR: URL of your running IB Gateway or TWS Client Portal API
# When running IB Gateway locally, this is always http://localhost:5000
# See setup instructions below.
IBKR_HOST=http://localhost:5000

# ── GLOBAL MODE (Kalshi + Polymarket) ───────────────────
# Polymarket uses a public API — no credentials needed for read access.
# The same KALSHI_EMAIL/PASSWORD above covers this mode too.

# ── MONETIZATION (Stripe) ───────────────────────────────
# Sign up at https://stripe.com to collect subscription payments.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_...

# ────────────────────────────────────────────────────────
# IBKR SETUP INSTRUCTIONS
# ────────────────────────────────────────────────────────
# 1. Download IB Gateway (lighter than TWS):
#    https://www.interactivebrokers.com/en/trading/ibgateway.php
#
# 2. Install and open IB Gateway. Log in with your IBKR username+password.
#    Select "Live Trading" or "Paper Trading" (Paper = fake money for testing).
#
# 3. In IB Gateway: go to Configure → Settings → API → Settings
#    - Check "Enable Client Portal API"
#    - Set Socket Port to 5000
#    - Check "Allow connections from localhost only" (for security)
#    - Click OK
#
# 4. Keep IB Gateway running while using ArbScout.
#    The app connects to http://localhost:5000 automatically.
#
# 5. Make sure "Event Contracts" are enabled in your IBKR account:
#    Client Portal → Account → Trading Permissions → Event Contracts
# ────────────────────────────────────────────────────────
