# Copy this file to .env.local and fill in your credentials

# Kalshi API credentials (sign up at https://kalshi.com)
# Without these, the app uses realistic demo data for Kalshi
KALSHI_EMAIL=your@email.com
KALSHI_PASSWORD=yourpassword

# Optional: Stripe for subscription payments (https://stripe.com)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_...
